{
  "name": "wallet-key-explorer",
  "version": "0.6.0",
  "private": true,
  "description": "Offline analysis tools for public Bitcoin cryptographic objects: extended keys, descriptors, multisig policies, addresses, scripts and PSBT.",
  "scripts": {
    "dev": "next dev --hostname localhost --port 3200",
    "build": "next build --webpack",
    "start": "next start --hostname localhost --port 3200",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js",
    "test:extended-key": "tsc -p tsconfig.test.json && node --test .test-dist/tests/extended-key.test.js",
    "test:descriptor": "tsc -p tsconfig.test.json && node --test .test-dist/tests/descriptor.test.js",
    "test:address": "tsc -p tsconfig.test.json && node --test .test-dist/tests/address.test.js",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "typescript": "^5"
  }
}
