{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "noEmit": true,
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".test-dist"
  ]
}
